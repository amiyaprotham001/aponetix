[Unit]
Description=APONETIX Flask Website
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/aponetix
Environment=APP_ENV=production
EnvironmentFile=/opt/aponetix/.env
ExecStart=/opt/aponetix/.venv/bin/waitress-serve --host=0.0.0.0 --port=5000 wsgi:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
